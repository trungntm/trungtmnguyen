{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "react": ["../../apps/web/node_modules/@types/react/index.d.ts"],
      "react-dom": ["../../apps/web/node_modules/@types/react-dom/index.d.ts"],
      "react/jsx-runtime": ["../../apps/web/node_modules/@types/react/jsx-runtime.d.ts"],
      "next": ["../../apps/web/node_modules/next"],
      "next/*": ["../../apps/web/node_modules/next/*"]
    },
    "typeRoots": ["../../apps/web/node_modules/@types"],
    "types": ["react", "react-dom", "node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
