{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "react": ["../../apps/web/node_modules/react"],
      "react-dom": ["../../apps/web/node_modules/react-dom"],
